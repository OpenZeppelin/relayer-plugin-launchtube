{
  "name": "@openzeppelin/relayer-plugin-launchtube",
  "version": "0.3.0",
  "description": "OpenZeppelin Relayer Plugin for Launchtube",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md",
    "package.json"
  ],
  "scripts": {
    "dev": "tsc --watch",
    "build": "tsc",
    "lint": "eslint . --fix",
    "lint:check": "eslint .",
    "lint:fix": "pnpm prettier:fix && pnpm lint:check && pnpm prettier:check",
    "prettier:check": "prettier -u --check '**/*.{js,ts,tsx,md}'",
    "prettier:fix": "prettier -u --write '**/*.{js,ts,tsx,md}'",
    "style": "pnpm lint:fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "jest",
    "clean": "rm -rf dist",
    "install-pnpm": "npm install -g pnpm",
    "install-deps": "pnpm install --frozen-lockfile --ignore-scripts --prefer-offline",
    "ci:version": "pnpm changeset version",
    "release": "node ./scripts/release.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/OpenZeppelin/relayer-plugin-launchtube.git"
  },
  "author": "OpenZeppelin <contact@openzeppelin.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/OpenZeppelin/relayer-plugin-launchtube/issues"
  },
  "homepage": "https://github.com/OpenZeppelin/relayer-plugin-launchtube#readme",
  "dependencies": {
    "@actions/exec": "^1.1.1",
    "@openzeppelin/relayer-sdk": "^1.6.0",
    "@stellar/stellar-sdk": "^11.2.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.7",
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.32.0",
    "@npmcli/fs": "3.1.0",
    "@types/glob": "^8.1.0",
    "@types/jest": "^29.5.12",
    "@types/lodash": "^4.17.6",
    "@types/node": "^22.13.14",
    "@typescript-eslint/eslint-plugin": "^8.38.0",
    "@typescript-eslint/parser": "^8.38.0",
    "code-style": "git+https://github.com/OpenZeppelin/configs.git",
    "eslint": "^9.22.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "globals": "^16.3.0",
    "jest": "^29.7.0",
    "nx": "^20.8.0",
    "prettier": "^3.0.0",
    "ts-jest": "^29.1.2",
    "typescript": "5.8.3",
    "typescript-eslint": "8.27.0"
  },
  "engines": {
    "node": ">=22.18.0",
    "npm": "use pnpm",
    "pnpm": ">=9",
    "yarn": "use pnpm"
  }
}
